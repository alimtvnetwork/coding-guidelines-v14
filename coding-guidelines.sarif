          "rules": [
            {
              "id": "STYLE-002",
              "name": "NoElseAfterReturn",
              "shortDescription": {
                "text": "Avoid `else` after `return` / `throw` / `break` / `continue`."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v14/blob/main/spec/02-coding-guidelines/01-cross-language/04-code-style/00-overview.md"
