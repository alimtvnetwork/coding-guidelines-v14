      "tool": {
        "driver": {
          "name": "coding-guidelines-nested-if-go",
          "version": "1.0.0",
          "informationUri": "https://github.com/alimtvnetwork/coding-guidelines-v14",
          "rules": [
            {
              "id": "CODE-RED-001",
              "name": "NoNestedIf",
              "shortDescription": {
                "text": "Nested if statements are forbidden \u2014 flatten with guard clauses."
              },
              "helpUri": "https://github.com/alimtvnetwork/coding-guidelines-v14/blob/main/spec/02-coding-guidelines/01-cross-language/04-code-style/00-overview.md"
            }
          ]
        }
      },
